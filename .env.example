# ===========================================
# AI Trading Bot Configuration
# ===========================================

# Claude API Key (required) - Uses Claude Opus for best analysis
ANTHROPIC_API_KEY=your-anthropic-api-key

# Alpaca API (for stock trading) - https://alpaca.markets
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # Use paper trading first!

# Crypto Exchange (via CCXT) - e.g. Coinbase, Binance
CRYPTO_EXCHANGE=coinbasepro
CRYPTO_API_KEY=your-crypto-api-key
CRYPTO_SECRET=your-crypto-secret
CRYPTO_PASSWORD=your-crypto-passphrase

# News API (optional, for extra news sources)
NEWS_API_KEY=your-newsapi-key

# Trading Configuration
TRADING_MODE=paper          # paper | live (START WITH PAPER!)
MAX_POSITION_PCT=0.10       # Max 10% of portfolio in one position
MAX_DAILY_TRADES=20         # Rate limit on trades per day
STOP_LOSS_PCT=0.05          # 5% stop loss default
TAKE_PROFIT_PCT=0.15        # 15% take profit default
ANALYSIS_INTERVAL_MIN=15    # Run analysis every 15 minutes

# Risk Management
MAX_PORTFOLIO_RISK=0.02     # Max 2% portfolio risk per trade
MAX_DRAWDOWN_PCT=0.10       # Halt trading at 10% drawdown
